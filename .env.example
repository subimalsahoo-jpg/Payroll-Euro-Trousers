# ============================================================================
# Euro-Trousers HRMS & Payroll - Environment Configuration
# Copy this file to ".env" and fill in real values for your deployment.
# Hostinger Application Manager compatible (stateless, cluster-ready).
# ============================================================================

# ---- Application ----
NODE_ENV=development
PORT=3000
APP_NAME=Euro-Trousers HRMS & Payroll
APP_COMPANY=Euro-Trousers
APP_URL=http://localhost:3000

# ---- Database (MySQL 8) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=divya_moolya_hrms
DB_USER=hrms_user
DB_PASSWORD=change_me
DB_CONNECTION_LIMIT=10
DB_TIMEZONE=+04:00

# ---- Security / Sessions ----
# Generate strong random secrets in production (e.g. `openssl rand -hex 32`)
SESSION_SECRET=replace_with_long_random_string
JWT_SECRET=replace_with_long_random_string
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=12
COOKIE_SECURE=false
ENABLE_2FA=false

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# ---- Localization ----
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=en,ar
DEFAULT_CURRENCY=AED

# ---- File Storage ----
UPLOAD_DIR=storage/uploads
DOCUMENT_DIR=storage/documents
PAYSLIP_DIR=storage/payslips
BACKUP_DIR=storage/backups
MAX_UPLOAD_MB=10

# ---- Email (SMTP) ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@euro-trousers.example
SMTP_PASSWORD=change_me
MAIL_FROM="Euro-Trousers HRMS <no-reply@euro-trousers.example>"

# ---- UAE Compliance / WPS ----
WPS_EMPLOYER_ID=000000000000000
WPS_BANK_ROUTING_CODE=000000000
WPS_SIF_VERSION=1.0
